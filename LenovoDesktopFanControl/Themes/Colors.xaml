<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <!-- Color system -->
        <Color x:Key="WindowColor">#090B18</Color>
        <Color x:Key="SurfaceColor">#11152A</Color>
        <Color x:Key="SurfaceElevatedColor">#181D38</Color>
        <Color x:Key="SurfaceHoverColor">#23294B</Color>
        <Color x:Key="BorderColor">#30375F</Color>
        <Color x:Key="AccentColor">#7787FF</Color>
        <Color x:Key="AccentDeepColor">#386EDC</Color>
        <Color x:Key="AccentHoverColor">#9A7DFF</Color>
        <Color x:Key="TextPrimaryColor">#F4F7FB</Color>
        <Color x:Key="TextOnAccentColor">#FFFFFF</Color>
        <Color x:Key="TextSecondaryColor">#B8BFDA</Color>
        <Color x:Key="TextMutedColor">#858EAF</Color>
        <Color x:Key="SuccessColor">#55D6A0</Color>
        <Color x:Key="WarningColor">#F5B942</Color>
        <Color x:Key="DangerColor">#FF6B7A</Color>
        <Color x:Key="UnsupportedColor">#B78CFF</Color>
        <Color x:Key="AccentSoftColor">#1F5B9DFF</Color>
        <Color x:Key="WarningSoftColor">#1FF5B942</Color>
        <Color x:Key="DangerSoftColor">#1FFF6B7A</Color>

        <SolidColorBrush x:Key="WindowBrush" Color="{DynamicResource WindowColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
        <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{DynamicResource SurfaceElevatedColor}" />
        <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{DynamicResource SurfaceHoverColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
        <SolidColorBrush x:Key="AccentDeepBrush" Color="{DynamicResource AccentDeepColor}" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="{DynamicResource AccentHoverColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextOnAccentBrush" Color="{DynamicResource TextOnAccentColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="{DynamicResource TextMutedColor}" />
        <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}" />
        <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}" />
        <SolidColorBrush x:Key="DangerBrush" Color="{DynamicResource DangerColor}" />
        <SolidColorBrush x:Key="UnsupportedBrush" Color="{DynamicResource UnsupportedColor}" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="{DynamicResource AccentSoftColor}" />
        <SolidColorBrush x:Key="WarningSoftBrush" Color="{DynamicResource WarningSoftColor}" />
        <SolidColorBrush x:Key="DangerSoftBrush" Color="{DynamicResource DangerSoftColor}" />

        <LinearGradientBrush x:Key="WindowGradientBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#090B18" Offset="0" />
                <GradientStop Color="#10132B" Offset="0.52" />
                <GradientStop Color="#170E2B" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SurfaceGradientBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#171C36" Offset="0" />
                <GradientStop Color="#12162C" Offset="0.62" />
                <GradientStop Color="#19122F" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#568CFF" Offset="0" />
                <GradientStop Color="#806EFF" Offset="0.55" />
                <GradientStop Color="#A855F7" Offset="1" />
        </LinearGradientBrush>

</ResourceDictionary>
