<Window x:Class="LenovoDesktopFanControl.Views.Controls.FanCurveEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:LenovoDesktopFanControl.Views.Markup"
        Title="{loc:Loc CurveEditorTitle}"
        Width="760" Height="520"
        MinWidth="680" MinHeight="470"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource AppFont}"
        AutomationProperties.Name="{loc:Loc CurveEditorTitle}">

    <Grid Margin="26,22,26,24"
          Background="{StaticResource WindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock x:Name="Header"
                       FontSize="21"
                       FontWeight="SemiBold" />
            <TextBlock Text="{loc:Loc CurveEditorSubtitle}"
                       Margin="0,5,0,0"
                       FontSize="12.5"
                       Foreground="{StaticResource TextMutedBrush}" />
            <TextBlock x:Name="FirmwareRangeText"
                       Margin="0,4,0,0"
                       FontSize="11"
                       Foreground="{StaticResource AccentBrush}" />
        </StackPanel>

        <!-- Interactive curve chart -->
        <Border Grid.Row="1"
                Padding="18,18,18,14"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="22" />
                </Grid.RowDefinitions>

                <!-- Y-axis -->
                <UniformGrid Grid.Row="0" Grid.Column="0" Rows="6" Margin="0,0,8,0">
                    <TextBlock Text="100%" VerticalAlignment="Top" HorizontalAlignment="Right" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="80%" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="60%" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="40%" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="20%" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="0%" VerticalAlignment="Bottom" HorizontalAlignment="Right" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                </UniformGrid>

                <Border Grid.Row="0" Grid.Column="1"
                        Background="{StaticResource SurfaceElevatedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="9" />

                <!-- Curve is visual-only and remains behind the sliders. -->
                <Canvas Grid.Row="0" Grid.Column="1"
                        x:Name="CurveCanvas"
                        Margin="1"
                        Panel.ZIndex="0"
                        Background="Transparent"
                        ClipToBounds="True"
                        IsHitTestVisible="False"
                        SizeChanged="CurveCanvas_SizeChanged" />

                <Grid Grid.Row="0" Grid.Column="1"
                      x:Name="SlidersGrid"
                      Margin="8,4"
                      Panel.ZIndex="1"
                      Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                </Grid>

                <Grid Grid.Row="1" Grid.Column="1" x:Name="LabelsGrid" Margin="8,4,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                </Grid>

                <UniformGrid Grid.Row="2" Grid.Column="1" Columns="10" Margin="8,3,8,0">
                    <TextBlock Text="30°C" HorizontalAlignment="Center" FontSize="9.5" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="40°C" HorizontalAlignment="Center" FontSize="9.5" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="50°C" HorizontalAlignment="Center" FontSize="9.5" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="55°C" HorizontalAlignment="Center" FontSize="9.5" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="60°C" HorizontalAlignment="Center" FontSize="9.5" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="65°C" HorizontalAlignment="Center" FontSize="9.5" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="70°C" HorizontalAlignment="Center" FontSize="9.5" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="80°C" HorizontalAlignment="Center" FontSize="9.5" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="90°C" HorizontalAlignment="Center" FontSize="9.5" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="100°C" HorizontalAlignment="Center" FontSize="9.5" Foreground="{StaticResource TextMutedBrush}" />
                </UniformGrid>
            </Grid>
        </Border>

        <!-- Validation feedback -->
        <Border Grid.Row="2"
                x:Name="ErrorText"
                AutomationProperties.LiveSetting="Assertive"
                Margin="0,14,0,0"
                Padding="12,9"
                Background="{StaticResource DangerSoftBrush}"
                BorderBrush="#55FF6B7A"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
            <TextBlock Text="{loc:Loc ValidationError}"
                       HorizontalAlignment="Center"
                       FontSize="12"
                       Foreground="{StaticResource DangerBrush}" />
        </Border>

        <!-- Dialog actions -->
        <Grid Grid.Row="3" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Content="{loc:Loc ResetDefault}"
                    Click="ResetDefault_Click"
                    Style="{StaticResource SecondaryButtonStyle}" />
            <Button Grid.Column="2"
                    Content="{loc:Loc Cancel}"
                    Click="Cancel_Click"
                    IsCancel="True"
                    MinWidth="94"
                    Style="{StaticResource SecondaryButtonStyle}" />
            <Button Grid.Column="4"
                    Content="{loc:Loc Apply}"
                    Click="Apply_Click"
                    IsDefault="True"
                    MinWidth="104"
                    Style="{StaticResource PrimaryButtonStyle}" />
        </Grid>
    </Grid>
</Window>
