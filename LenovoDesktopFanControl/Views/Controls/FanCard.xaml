<UserControl x:Class="LenovoDesktopFanControl.Views.Controls.FanCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LenovoDesktopFanControl.Views.Converters"
             xmlns:loc="clr-namespace:LenovoDesktopFanControl.Views.Markup"
             xmlns:local="clr-namespace:LenovoDesktopFanControl.Views.Controls"
             Background="Transparent"
             UseLayoutRounding="True"
             AutomationProperties.Name="{Binding FanName}"
             AutomationProperties.ItemType="{loc:Loc AutomationFanControl}">
    <UserControl.Resources>
        <conv:RpmToStringConverter x:Key="RpmConverter" />
        <conv:TempToStringConverter x:Key="TempConverter" />
        <conv:TemperatureToBrushConverter x:Key="TemperatureBrushConverter"
                                           CoolBrush="{StaticResource SuccessBrush}"
                                           ElevatedBrush="{StaticResource TemperatureYellowBrush}"
                                           HotBrush="{StaticResource TemperatureOrangeBrush}"
                                           CriticalBrush="{StaticResource DangerBrush}"
                                           UnavailableBrush="{StaticResource TextMutedBrush}" />
        <conv:BoolToVisibilityConverter x:Key="Bool2Vis" />
        <conv:BoolToInverseVisibilityConverter x:Key="Bool2InvVis" />
    </UserControl.Resources>

    <Border x:Name="CardRoot"
            Margin="8" Padding="20" CornerRadius="14"
            Loaded="CardRoot_Loaded">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="18"
                                          ShadowDepth="4"
                                          Direction="270"
                                          Opacity="0.18"
                                          Color="#000000" />
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="#665B9DFF" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Fan identity -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="38" Height="38"
                        Background="{StaticResource AccentSoftBrush}"
                        CornerRadius="10">
                    <local:FanIcon Width="22" Height="22" />
                </Border>

                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Grid>
                        <Button Command="{Binding EditNameCommand}"
                                Style="{StaticResource RenameableTextButtonStyle}"
                                Visibility="{Binding IsEditingName, Converter={StaticResource Bool2InvVis}}"
                                AutomationProperties.Name="{loc:Loc TooltipEditFanName}"
                                AutomationProperties.HelpText="{loc:Loc TooltipEditFanName}">
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding FanName}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       TextTrimming="CharacterEllipsis" />
                        </Button>
                        <TextBox MaxLength="48"
                                 Padding="4,2"
                                 FontSize="15"
                                 FontWeight="SemiBold"
                                 Text="{Binding FanName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                 Visibility="{Binding IsEditingName, Converter={StaticResource Bool2Vis}}"
                                 IsVisibleChanged="FanNameEditor_IsVisibleChanged"
                                 KeyDown="FanNameEditor_KeyDown"
                                 LostKeyboardFocus="FanNameEditor_LostKeyboardFocus"
                                 ToolTip="{loc:Loc TooltipEditFanName}"
                                 AutomationProperties.Name="{loc:Loc FanName}"
                                 AutomationProperties.HelpText="{loc:Loc TooltipEditFanName}" />
                    </Grid>
                    <TextBlock Text="{loc:Loc FanStatusLive}"
                               Margin="0,2,0,0"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>

                <Border Grid.Column="2"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        Background="{StaticResource AccentSoftBrush}"
                        CornerRadius="8"
                        Visibility="{Binding IsBusy, Converter={StaticResource Bool2Vis}}">
                    <TextBlock Text="{loc:Loc Applying}"
                               FontSize="10.5"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" />
                </Border>
            </Grid>

            <!-- Live readings -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="CurrentSpeedLabel"
                               Text="{loc:Loc CurrentSpeed}"
                               Style="{StaticResource EyebrowTextStyle}" />
                    <TextBlock Text="{Binding CurrentRpm, Converter={StaticResource RpmConverter}}"
                               Margin="0,4,0,0"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding FirmwareRpmRange}"
                               Margin="0,3,0,0"
                               FontSize="10.5"
                               Foreground="{StaticResource TextMutedBrush}"
                               Visibility="{Binding HasFirmwareRpmRange, Converter={StaticResource Bool2Vis}}" />
                    <ItemsControl ItemsSource="{Binding Channels}"
                                  Margin="0,10,0,0"
                                  Visibility="{Binding HasMultipleChannels, Converter={StaticResource Bool2Vis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="10.5"
                                               Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="12,0,0,0"
                                               Text="{Binding CurrentRpm, Converter={StaticResource RpmConverter}}"
                                               FontSize="10.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <Border Grid.Column="1"
                        MinWidth="86"
                        Padding="12,9"
                        VerticalAlignment="Top"
                        Background="{StaticResource SurfaceElevatedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="9">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Temperature}"
                                   HorizontalAlignment="Center"
                                   FontSize="10.5"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding Temperature, Converter={StaticResource TempConverter}}"
                                   Margin="0,3,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding Temperature, Converter={StaticResource TemperatureBrushConverter}}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Current output -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ProgressBar Value="{Binding SpeedPercentage, Mode=OneWay}"
                             AutomationProperties.LabeledBy="{Binding ElementName=CurrentSpeedLabel}"
                             Minimum="0" Maximum="100" />
                <TextBlock Grid.Row="1"
                           Margin="0,6,0,0"
                           HorizontalAlignment="Right"
                           FontSize="10.5"
                           Foreground="{StaticResource TextMutedBrush}">
                    <Run Text="{Binding SpeedPercentage, Mode=OneWay}" /><Run Text="{loc:Loc SpeedSuffix}" />
                </TextBlock>
            </Grid>

            <!-- Target speed -->
            <Grid Grid.Row="3" Margin="0,0,0,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                    <TextBlock x:Name="TargetSpeedLabel"
                               Text="{loc:Loc TargetSpeed}"
                               Style="{StaticResource EyebrowTextStyle}" />
                    <TextBlock HorizontalAlignment="Right"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}">
                        <Run Text="{Binding TargetSpeedPercentage}" /><Run Text="%" />
                    </TextBlock>
                </Grid>
                <Slider Grid.Row="1"
                        Margin="0,8,0,0"
                        AutomationProperties.LabeledBy="{Binding ElementName=TargetSpeedLabel}"
                        AutomationProperties.HelpText="{loc:Loc AutomationTargetSpeedHelp}"
                        ToolTip="{loc:Loc TooltipManualSpeed}"
                        Style="{StaticResource HorizontalSliderStyle}"
                        Value="{Binding TargetSpeedPercentage}"
                        Minimum="50" Maximum="100"
                        TickFrequency="10"
                        IsSnapToTickEnabled="False" />
                <Grid Grid.Row="2" Margin="0,2,0,0">
                    <TextBlock Text="50%" FontSize="9.5" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="100%" HorizontalAlignment="Right" FontSize="9.5" Foreground="{StaticResource TextMutedBrush}" />
                </Grid>
            </Grid>

            <!-- Actions -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Content="{loc:Loc EditCurve}"
                        Command="{Binding EditCurveCommand}"
                        AutomationProperties.HelpText="{loc:Loc TooltipEditCurve}"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button Grid.Column="2"
                        Content="{loc:Loc ApplySpeed}"
                        Command="{Binding ApplySpeedCommand}"
                        AutomationProperties.HelpText="{loc:Loc TooltipManualSpeed}"
                        Style="{StaticResource PrimaryButtonStyle}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
