<Window x:Class="LenovoDesktopFanControl.Views.Controls.TemperatureChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Temperature history"
        Width="760" Height="500" MinWidth="560" MinHeight="390"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource AppFont}">
    <Grid Margin="26,22,26,24"
          Background="{StaticResource WindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="{Binding SourceName}" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="Temperature history · detailed for the last hour, compacted up to 12 hours"
                       Margin="0,5,0,0" Foreground="{StaticResource TextMutedBrush}" />
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,22,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Padding="13,9" Margin="0,0,8,0" CornerRadius="9" Background="{StaticResource SurfaceElevatedBrush}">
                <StackPanel><TextBlock Text="CURRENT" FontSize="10" Foreground="{StaticResource TextMutedBrush}" /><TextBlock Text="{Binding CurrentLabel}" Margin="0,3,0,0" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" /></StackPanel>
            </Border>
            <Border Grid.Column="1" Padding="13,9" Margin="4,0" CornerRadius="9" Background="{StaticResource SurfaceElevatedBrush}">
                <StackPanel><TextBlock Text="LOW" FontSize="10" Foreground="{StaticResource TextMutedBrush}" /><TextBlock Text="{Binding LowLabel}" Margin="0,3,0,0" FontSize="18" FontWeight="SemiBold" /></StackPanel>
            </Border>
            <Border Grid.Column="2" Padding="13,9" Margin="8,0,0,0" CornerRadius="9" Background="{StaticResource SurfaceElevatedBrush}">
                <StackPanel><TextBlock Text="HIGH" FontSize="10" Foreground="{StaticResource TextMutedBrush}" /><TextBlock Text="{Binding HighLabel}" Margin="0,3,0,0" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TemperatureOrangeBrush}" /></StackPanel>
            </Border>
        </Grid>
        <Border Grid.Row="2" Padding="14" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="13">
            <Grid>
                <Canvas x:Name="ChartCanvas" ClipToBounds="True" SizeChanged="ChartCanvas_SizeChanged" />
                <TextBlock x:Name="EmptyText" Text="Temperature history will appear after the next reading."
                           HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
            </Grid>
        </Border>
    </Grid>
</Window>
